---
interface Props {
  title?: string;
  description?: string;
}

const { title = "いのろぐ", description = "AzureとAWSをいじり倒すブログ" } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === "いのろぐ" ? title : `${title} | いのろぐ`}</title>

    <!-- AdSense: 承認済みならここにタグを貼る -->
    <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-wrapper">
      <header class="site-header">
        <div class="header-inner">
          <a href="/" class="logo">
            <span class="logo-main">いのろぐ</span>
            <span class="logo-sub">AzureとAWSをいじり倒すブログ</span>
          </a>
          <nav class="nav">
            <a href="/blog">tech</a>
            <a href="/about">about</a>
          </nav>
        </div>
      </header>

      <main class="main-content">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <p>© {new Date().getFullYear()} いのろぐ</p>
          <p>built with astro + azure</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --font-sans: "Noto Sans JP", system-ui, sans-serif;
    --color-text-primary: #1a1a1a;
    --color-text-secondary: #555;
    --color-text-tertiary: #999;
    --color-border: rgba(0, 0, 0, 0.1);
    --color-border-hover: rgba(0, 0, 0, 0.2);
    --color-bg: #fff;
    --color-bg-secondary: #f7f7f5;
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-text-primary: #f0f0f0;
      --color-text-secondary: #aaa;
      --color-text-tertiary: #666;
      --color-border: rgba(255, 255, 255, 0.1);
      --color-border-hover: rgba(255, 255, 255, 0.2);
      --color-bg: #141414;
      --color-bg-secondary: #1e1e1e;
    }
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-primary);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  .site-wrapper {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Header */
  .site-header {
    border-bottom: 0.5px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
  }

  .logo {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
  }

  .logo-main {
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text-primary);
    letter-spacing: -0.3px;
  }

  .logo-sub {
    font-size: 11px;
    color: var(--color-text-tertiary);
    font-weight: 400;
  }

  .nav {
    display: flex;
    gap: 20px;
  }

  .nav a {
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .nav a:hover {
    color: var(--color-text-primary);
  }

  /* Footer */
  .site-footer {
    border-top: 0.5px solid var(--color-border);
    margin-top: 3rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    padding: 1.25rem 0;
    font-size: 12px;
    color: var(--color-text-tertiary);
  }
</style>
