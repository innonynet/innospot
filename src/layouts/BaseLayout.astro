---
import { getCollection } from "astro:content";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title = "inolog",
  description = "Terraform / Azure / Kubernetes を中心に、設計判断・移行戦略・組織論まで踏み込んで書きます。",
  ogImage = "/og-default.svg",
  ogType = "website",
} = Astro.props;

const posts = await getCollection("blog");
const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
const recentCount = posts.filter((p) => new Date(p.data.date) > thirtyDaysAgo).length;

const siteUrl = Astro.site?.href?.replace(/\/$/, "") ?? "https://innony.net";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const pageTitle = title === "inolog" ? title : `${title} | inolog`;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="inolog" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        if (saved === "light" || (!saved && prefersLight)) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-wrapper">
      <header class="site-header">
        <div class="header-inner">
          <a href="/" class="logo">
            <span class="logo-dot"></span>
            <span class="logo-text">inolog</span>
          </a>
          <nav class="nav">
            <a href="/" class="nav-link">記事</a>
            <a href="/tags" class="nav-link">タグ</a>
            <a href="/about" class="nav-link">about</a>
            {recentCount > 0 && (
              <a href="/" class="nav-badge">新着 {recentCount}</a>
            )}
            <button id="theme-toggle" class="theme-btn" aria-label="テーマ切り替え">
              <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
              <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </button>
          </nav>
        </div>
      </header>

      <main class="main-content">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} inolog</span>
          <span>Terraform · Azure · Kubernetes</span>
        </div>
      </footer>
    </div>

    <script>
      const toggle = document.getElementById("theme-toggle");
      const html = document.documentElement;

      toggle?.addEventListener("click", () => {
        const isLight = html.getAttribute("data-theme") === "light";
        if (isLight) {
          html.removeAttribute("data-theme");
          localStorage.setItem("theme", "dark");
        } else {
          html.setAttribute("data-theme", "light");
          localStorage.setItem("theme", "light");
        }
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ── Dark (default) ── */
  :root {
    --font-sans: "Noto Sans JP", "Inter", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", ui-monospace, monospace;

    --bg:          #080808;
    --bg-card:     #101010;
    --bg-card-2:   #161616;
    --bg-tag:      rgba(99, 102, 241, 0.1);
    --border:      rgba(255, 255, 255, 0.07);
    --border-2:    rgba(255, 255, 255, 0.13);

    --text-1:      #efefef;
    --text-2:      #888;
    --text-3:      #555;
    --accent:      #6366f1;
    --accent-text: #a5b4fc;

    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;

    /* Shiki: dark default */
    --shiki-light:    #e1e4e8;
    --shiki-light-bg: #0d1117;
    --shiki-dark:     #e1e4e8;
    --shiki-dark-bg:  #0d1117;
  }

  /* ── Light override ── */
  [data-theme="light"] {
    --bg:          #ffffff;
    --bg-card:     #f7f7f5;
    --bg-card-2:   #efefed;
    --bg-tag:      rgba(99, 102, 241, 0.08);
    --border:      rgba(0, 0, 0, 0.08);
    --border-2:    rgba(0, 0, 0, 0.15);

    --text-1:      #111111;
    --text-2:      #555;
    --text-3:      #999;
    --accent-text: #5254d4;

    --shiki-light:    #24292e;
    --shiki-light-bg: #f6f8fa;
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-1);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    transition: background 0.15s, color 0.15s;
  }

  a { color: inherit; text-decoration: none; }

  /* ── Shiki ── */
  .astro-code,
  .astro-code span {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
    font-style: var(--shiki-dark-font-style) !important;
    font-weight: var(--shiki-dark-font-weight) !important;
    text-decoration: var(--shiki-dark-text-decoration) !important;
  }

  [data-theme="light"] .astro-code,
  [data-theme="light"] .astro-code span {
    color: var(--shiki-light) !important;
    background-color: var(--shiki-light-bg) !important;
    font-style: var(--shiki-light-font-style) !important;
    font-weight: var(--shiki-light-font-weight) !important;
    text-decoration: var(--shiki-light-text-decoration) !important;
  }

  /* ── Layout ── */
  .site-wrapper {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* ── Header ── */
  .site-header {
    padding: 1.25rem 0;
    margin-bottom: 0;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-1);
    letter-spacing: -0.3px;
    font-family: "Inter", system-ui, sans-serif;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link {
    font-size: 13px;
    color: var(--text-2);
    padding: 4px 10px;
    border-radius: var(--radius-md);
    transition: color 0.1s;
  }

  .nav-link:hover {
    color: var(--text-1);
  }

  .nav-badge {
    font-size: 12px;
    color: var(--text-1);
    border: 1px solid var(--border-2);
    border-radius: 20px;
    padding: 3px 12px;
    margin-left: 4px;
    transition: border-color 0.1s;
  }

  .nav-badge:hover {
    border-color: var(--accent);
    color: var(--accent-text);
  }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    padding: 0;
    margin-left: 4px;
    border-radius: var(--radius-md);
    transition: color 0.1s;
  }

  .theme-btn:hover { color: var(--text-1); }

  /* dark default: show sun (switch TO light) */
  .theme-btn .icon-moon { display: none; }
  .theme-btn .icon-sun  { display: block; }

  /* light mode: show moon (switch TO dark) */
  [data-theme="light"] .theme-btn .icon-moon { display: block; }
  [data-theme="light"] .theme-btn .icon-sun  { display: none; }

  /* ── Main ── */
  .main-content {
    min-height: 60vh;
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    padding: 1.5rem 0;
    font-size: 12px;
    color: var(--text-3);
  }
</style>
