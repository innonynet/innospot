---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const allPosts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = allPosts.findIndex((p) => p.slug === post.slug);
const prevPost = allPosts[currentIndex + 1] ?? null;
const nextPost = allPosts[currentIndex - 1] ?? null;

function formatDate(date: Date) {
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.thumbnail}
>
  <article class="article">
    <header class="article-header">
      <div class="article-meta">
        <div class="article-tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <span class="article-date">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          {post.data.readingTime && <> · 読了 {post.data.readingTime}分</>}
        </span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
    </header>

    {toc.length >= 3 && (
      <nav class="toc" aria-label="目次">
        <p class="toc-title">目次</p>
        <ol class="toc-list">
          {toc.map((h) => (
            <li class:list={["toc-item", `toc-h${h.depth}`]}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="article-body">
      <Content />
    </div>

    <nav class="article-nav">
      {prevPost && (
        <a href={`/blog/${prevPost.slug}`} class="nav-link nav-prev">
          <span class="nav-label">← 前の記事</span>
          <span class="nav-title">{prevPost.data.title}</span>
        </a>
      )}
      {nextPost && (
        <a
          href={`/blog/${nextPost.slug}`}
          class:list={["nav-link nav-next", !prevPost && "nav-only"]}
        >
          <span class="nav-label">次の記事 →</span>
          <span class="nav-title">{nextPost.data.title}</span>
        </a>
      )}
    </nav>

    <div class="back-link">
      <a href="/">← 一覧に戻る</a>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 680px;
    padding-top: 2rem;
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .article-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 11px;
    color: var(--accent-text);
    background: var(--bg-tag);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  .article-date {
    font-size: 12px;
    color: var(--text-3);
  }

  .article-title {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.5px;
    margin-bottom: 0.875rem;
    color: var(--text-1);
  }

  .article-description {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.75;
  }

  /* ToC */
  .toc {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
  }

  .toc-title {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.625rem;
  }

  .toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .toc-item a {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.4;
    transition: color 0.1s;
  }

  .toc-item a:hover {
    color: var(--text-1);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .toc-h3 { padding-left: 1rem; }

  /* Body */
  .article-body {
    font-size: 15px;
    line-height: 1.85;
  }

  .article-body :global(h2) {
    font-size: 18px;
    font-weight: 700;
    margin: 2.25rem 0 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-1);
    scroll-margin-top: 1rem;
  }

  .article-body :global(h3) {
    font-size: 15px;
    font-weight: 600;
    margin: 1.75rem 0 0.625rem;
    color: var(--text-1);
    scroll-margin-top: 1rem;
  }

  .article-body :global(p) {
    margin-bottom: 1.1rem;
    color: var(--text-2);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 1.1rem 1.25rem;
    color: var(--text-2);
  }

  .article-body :global(li) { margin-bottom: 0.35rem; }

  .article-body :global(strong) { color: var(--text-1); }

  .article-body :global(a) {
    color: var(--accent-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1px 5px;
  }

  .article-body :global(pre) {
    border-radius: var(--radius-md);
    padding: 1.125rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    border: 1px solid var(--border);
  }

  .article-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  .article-body :global(blockquote) {
    border-left: 2px solid var(--border-2);
    padding-left: 1rem;
    color: var(--text-3);
    margin-bottom: 1.1rem;
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin-bottom: 1.25rem;
  }

  .article-body :global(th),
  .article-body :global(td) {
    padding: 8px 12px;
    border: 1px solid var(--border);
    text-align: left;
    color: var(--text-2);
  }

  .article-body :global(th) {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-1);
  }

  .article-body :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    display: block;
    margin: 0 auto 0.25rem;
  }

  .article-body :global(figure) {
    margin: 0 0 1.25rem;
    text-align: center;
  }

  .article-body :global(figcaption) {
    font-size: 12px;
    color: var(--text-3);
    margin-top: 0.375rem;
  }

  /* Nav */
  .article-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.875rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    border-color: var(--border-2);
    background: var(--bg-card);
  }

  .nav-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-only { grid-column: 2; }

  .nav-label {
    font-size: 11px;
    color: var(--text-3);
  }

  .nav-title {
    font-size: 13px;
    color: var(--text-1);
    line-height: 1.4;
  }

  .back-link {
    margin-top: 1.5rem;
    font-size: 13px;
    color: var(--text-2);
    transition: color 0.1s;
  }

  .back-link a:hover { color: var(--text-1); }
</style>
