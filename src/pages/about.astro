---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="いのろぐについて">
  <div class="about">
    <h1>About</h1>

    <!-- プロフィール -->
    <div class="profile">
      <div class="profile-avatar">い</div>
      <div class="profile-info">
        <p class="profile-name">いの</p>
        <p class="profile-bio">AzureとAWSをいじり倒しているエンジニア。クラウドインフラ・DevOps・Web開発あたりが好き。</p>
        <div class="profile-links">
          <a href="https://x.com/innonynet" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href="https://github.com/innonynet" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://qiita.com/innonynet" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm.37 18.374a6.375 6.375 0 1 1 2.168-12.374l1.285-1.286a.75.75 0 1 1 1.06 1.06l-1.395 1.396a6.373 6.373 0 0 1-3.118 11.204zm4.13-2.504a.75.75 0 1 1-1.06-1.06l1.5-1.5a.75.75 0 1 1 1.06 1.06l-1.5 1.5z"/></svg>
            Qiita
          </a>
          <a href="https://zenn.dev/innonynet" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M.264 23.771h4.984c.264 0 .498-.147.645-.352L19.614.874c.176-.293-.029-.674-.381-.674h-4.72c-.235 0-.44.117-.557.323L.03 23.361c-.088.176-.029.41.234.41zM17.445 23.419l6.479-10.408c.205-.323-.029-.733-.41-.733h-4.691c-.205 0-.41.117-.527.323l-6.538 10.467c-.176.264.029.616.352.616h4.779c.234 0 .44-.117.556-.265z"/></svg>
            Zenn
          </a>
        </div>
      </div>
    </div>

    <div class="about-body">
      <h2>このブログについて</h2>
      <p>
        AzureとAWSを中心にクラウドインフラ・DevOps・開発ツールなどを実際にいじりながら学んだことを書いていきます。
      </p>
      <h2>扱うテーマ</h2>
      <ul>
        <li>Azure / AWS のサービス検証</li>
        <li>インフラ構成・IaC（Terraform / Bicep）</li>
        <li>CI/CD・GitHub Actions</li>
        <li>Web開発（Astro, Node.js など）</li>
      </ul>
      <h2>サイト構成</h2>
      <p>
        Astroで構築し、Azure Static Web Appsでホスティングしています。
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: 640px;
  }

  .about h1 {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  /* プロフィール */
  .profile {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .profile-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-bg-secondary);
    border: 0.5px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .profile-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .profile-bio {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .profile-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 2px;
  }

  .profile-links a {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--color-text-tertiary);
    text-decoration: none;
  }

  .profile-links a:hover {
    color: var(--color-text-primary);
  }

  /* 本文 */
  .about-body {
    font-size: 15px;
    line-height: 1.85;
    color: var(--color-text-secondary);
  }

  .about-body h2 {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 1.75rem 0 0.5rem;
  }

  .about-body p {
    margin-bottom: 0.75rem;
  }

  .about-body ul {
    margin: 0 0 0.75rem 1.2rem;
  }

  .about-body li {
    margin-bottom: 0.25rem;
  }
</style>
