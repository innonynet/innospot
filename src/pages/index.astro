---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sorted = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const allTags = ["すべて", ...new Set(sorted.flatMap((p) => p.data.tags))];
const featured = sorted[0];
const rest = sorted.slice(1);

function formatDate(d: Date) {
  return d.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  });
}
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">
      いのろぐ
    </h1>
    <p class="hero-subtitle">
      クラウドインフラ を中心に。
    </p>
  </section>

  <!-- Tag filter -->
  <div class="filter-row">
    {allTags.map((tag, i) => (
      <button class:list={["f-btn", i === 0 && "active"]} data-tag={tag}>
        {tag}
      </button>
    ))}
  </div>

  <!-- Articles -->
  <section class="articles">
    <p class="section-label">新着記事</p>

    <!-- Featured -->
    <article
      class="card card-featured"
      data-tags={JSON.stringify(featured.data.tags)}
      id="card-featured"
    >
      <div class="card-accent"></div>
      <div class="card-tags">
        {featured.data.tags.map((tag, i) => (
          <span class="tag">{tag}{i < featured.data.tags.length - 1 ? " ·" : ""}</span>
        ))}
      </div>
      <a href={`/blog/${featured.slug}`} class="card-title-lg">
        {featured.data.title}
      </a>
      <p class="card-desc">{featured.data.description}</p>
      <div class="card-meta">
        <time class="meta-date">{formatDate(featured.data.date)}</time>
        <div class="meta-right">
          {featured.data.readingTime && (
            <span class="meta-item">読了 {featured.data.readingTime}分</span>
          )}
          {featured.data.likes != null && (
            <span class="meta-item meta-likes">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
              </svg>
              {featured.data.likes}
            </span>
          )}
        </div>
      </div>
    </article>

    <!-- Grid -->
    <div class="cards-grid" id="cards-grid">
      {rest.map((post) => (
        <article class="card" data-tags={JSON.stringify(post.data.tags)}>
          <div class="card-tags">
            {post.data.tags.map((tag, i) => (
              <span class="tag">{tag}{i < post.data.tags.length - 1 ? " ·" : ""}</span>
            ))}
          </div>
          <a href={`/blog/${post.slug}`} class="card-title-md">
            {post.data.title}
          </a>
          <p class="card-desc card-desc-clamp">{post.data.description}</p>
          <div class="card-meta">
            <time class="meta-date">{formatDate(post.data.date)}</time>
            <div class="meta-right">
              {post.data.readingTime && (
                <span class="meta-item">{post.data.readingTime}分</span>
              )}
              {post.data.likes != null && (
                <span class="meta-item meta-likes">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                  </svg>
                  {post.data.likes}
                </span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".f-btn");
  const featuredEl = document.getElementById("card-featured") as HTMLElement;
  const gridCards = document.querySelectorAll<HTMLElement>("#cards-grid .card");

  function applyFilter(tag: string) {
    const isAll = tag === "すべて";

    buttons.forEach((b) =>
      b.classList.toggle("active", b.dataset.tag === tag)
    );

    const featuredTags: string[] = JSON.parse(featuredEl.dataset.tags ?? "[]");
    featuredEl.style.display =
      isAll || featuredTags.includes(tag) ? "" : "none";

    gridCards.forEach((card) => {
      const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
      card.style.display = isAll || tags.includes(tag) ? "" : "none";
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.tag ?? "すべて"));
  });
</script>

<style>
  /* ── Hero ── */
  .hero {
    padding: 2.5rem 0 2rem;
  }

  .hero-title {
    font-size: clamp(34px, 6vw, 56px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -1.5px;
    color: var(--text-1);
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.85;
    max-width: 540px;
  }

  /* ── Filter ── */
  .filter-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .f-btn {
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-2);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: color 0.1s, background 0.1s, border-color 0.1s;
  }

  .f-btn:hover { color: var(--text-1); }

  .f-btn.active {
    background: var(--bg-card-2);
    border-color: var(--border-2);
    color: var(--text-1);
  }

  /* ── Section ── */
  .articles {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-3);
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  /* ── Card base ── */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: border-color 0.15s;
  }

  .card:hover { border-color: var(--border-2); }

  /* ── Featured ── */
  .card-featured {
    padding: 0 2rem 2rem;
    gap: 0.875rem;
  }

  .card-accent {
    height: 2px;
    background: linear-gradient(90deg, #6366f1 0%, #a78bfa 50%, #60a5fa 100%);
    border-radius: 0 0 2px 2px;
    margin: 0 -2rem 1rem;
  }

  /* ── Tags ── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tag {
    font-size: 11px;
    color: var(--accent-text);
    background: var(--bg-tag);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
    line-height: 1.6;
  }

  /* ── Titles ── */
  .card-title-lg {
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    color: var(--text-1);
    line-height: 1.4;
    letter-spacing: -0.4px;
    transition: color 0.1s;
  }

  .card-title-lg:hover { color: var(--accent-text); }

  .card-title-md {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-1);
    line-height: 1.45;
    letter-spacing: -0.3px;
    transition: color 0.1s;
  }

  .card-title-md:hover { color: var(--accent-text); }

  /* ── Description ── */
  .card-desc {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.75;
    flex: 1;
  }

  .card-desc-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Meta ── */
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.25rem;
  }

  .meta-date {
    font-size: 12px;
    color: var(--text-3);
  }

  .meta-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .meta-item {
    font-size: 12px;
    color: var(--text-3);
  }

  .meta-likes {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* ── Grid ── */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  @media (max-width: 580px) {
    .cards-grid { grid-template-columns: 1fr; }
    .hero-title { letter-spacing: -0.8px; }
  }
</style>
