---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sorted = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// タグ一覧を動的に生成
const tags = ["all", ...new Set(sorted.map((p) => p.data.tag))];

// サムネイルのカラー定義（frontmatterのtagに対応）
function thumbBg(tag: string): string {
  const map: Record<string, string> = {
    azure:  "#E6F1FB",
    aws:    "#FAEEDA",
    cloud:  "#E1F5EE",
    dev:    "#EEEDFE",
    infra:  "#F1EFE8",
  };
  return map[tag] ?? "#F1EFE8";
}

function thumbFg(tag: string): string {
  const map: Record<string, string> = {
    azure:  "#185FA5",
    aws:    "#854F0B",
    cloud:  "#0F6E56",
    dev:    "#534AB7",
    infra:  "#5F5E5A",
  };
  return map[tag] ?? "#5F5E5A";
}

function thumbIcon(tag: string): string {
  const map: Record<string, string> = {
    azure:  '<path d="M8 3L14 8L10 8L10 13L6 13L6 8L2 8Z" fill="currentColor"/>',
    aws:    '<rect x="2" y="6" width="12" height="7" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M5 6V5a3 3 0 0 1 6 0v1" stroke="currentColor" stroke-width="1.5" fill="none"/>',
    cloud:  '<path d="M5 14a3 3 0 0 1 0-6 5 5 0 0 1 9.9-1A3 3 0 0 1 15 14Z" stroke="currentColor" stroke-width="1.5" fill="none"/>',
    dev:    '<polyline points="4,6 2,8 4,10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><polyline points="12,6 14,8 12,10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><line x1="9" y1="4" x2="7" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    infra:  '<rect x="2" y="3" width="12" height="4" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="2" y="9" width="12" height="4" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>',
  };
  return map[tag] ?? map["infra"];
}
---

<BaseLayout title="いのろぐ" description="AzureとAWSをいじり倒すブログ">
  <!-- フィルター -->
  <div class="filter-row">
    {tags.map((tag) => (
      <button
        class={`f-btn ${tag === "all" ? "active" : ""}`}
        data-tag={tag}
        onclick="filterPosts(this)"
      >
        {tag}
      </button>
    ))}
  </div>

  <!-- 記事リスト -->
  <div class="post-list" id="post-list">
    {sorted.map((post) => (
      <article class="post-item" data-tag={post.data.tag}>
        <div class="thumb" style={`background: ${thumbBg(post.data.tag)}`}>
          <svg viewBox="0 0 16 16" style={`color: ${thumbFg(post.data.tag)}`}>
            <Fragment set:html={thumbIcon(post.data.tag)} />
          </svg>
        </div>
        <div class="post-body">
          <div class="post-top">
            <span class="post-tag">{post.data.tag}</span>
            <span class="post-meta">
              {new Date(post.data.date).toLocaleDateString("ja-JP", { month: "2-digit", day: "2-digit" }).replace("/", ".")}
              · {post.data.readingTime ?? "?"} min
            </span>
          </div>
          <a href={`/blog/${post.slug}`} class="post-title">{post.data.title}</a>
          <p class="post-excerpt">{post.data.description}</p>
          <a href={`/blog/${post.slug}`} class="read-more">続きを読む →</a>
        </div>
      </article>
    ))}
  </div>

  <!-- もっと見る -->
  <div class="load-wrap">
    <span class="count" id="count-label"></span>
    <button class="load-btn" id="load-btn" onclick="loadMore()">もっと見る</button>
  </div>
</BaseLayout>

<script>
  const BATCH = 6;
  let shown = 0;
  let currentTag = "all";

  function getItems(): NodeListOf<HTMLElement> {
    return document.querySelectorAll<HTMLElement>(".post-item");
  }

  function getFiltered(): HTMLElement[] {
    return Array.from(getItems()).filter(
      (el) => currentTag === "all" || el.dataset.tag === currentTag
    );
  }

  function render() {
    const all = Array.from(getItems());
    const filtered = getFiltered();

    all.forEach((el) => (el.style.display = "none"));
    filtered.slice(0, shown).forEach((el) => (el.style.display = "flex"));

    const btn = document.getElementById("load-btn") as HTMLButtonElement;
    const label = document.getElementById("count-label")!;
    label.textContent = `${Math.min(shown, filtered.length)} / ${filtered.length} 件`;

    if (shown >= filtered.length) {
      btn.disabled = true;
      btn.textContent = "すべて表示済み";
    } else {
      btn.disabled = false;
      btn.textContent = "もっと見る";
    }
  }

  (window as any).loadMore = function () {
    const filtered = getFiltered();
    shown = Math.min(shown + BATCH, filtered.length);
    render();
  };

  (window as any).filterPosts = function (btn: HTMLElement) {
    document.querySelectorAll(".f-btn").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    currentTag = btn.dataset.tag ?? "all";
    shown = 0;
    (window as any).loadMore();
  };

  // 初期表示
  (window as any).loadMore();
</script>

<style>
  .filter-row {
    display: flex;
    gap: 8px;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .f-btn {
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 20px;
    border: 0.5px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .f-btn:hover:not(.active) {
    background: var(--color-bg-secondary);
  }

  .f-btn.active {
    background: var(--color-text-primary);
    color: var(--color-bg);
    border-color: var(--color-text-primary);
  }

  .post-list {
    border-top: 0.5px solid var(--color-border);
  }

  .post-item {
    border-bottom: 0.5px solid var(--color-border);
    padding: 1rem 0;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .thumb {
    width: 56px;
    height: 40px;
    border-radius: 6px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thumb svg {
    width: 20px;
    height: 20px;
  }

  .post-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .post-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .post-tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    border: 0.5px solid var(--color-border);
    white-space: nowrap;
  }

  .post-meta {
    font-size: 11px;
    color: var(--color-text-tertiary);
  }

  .post-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: 1.4;
    text-decoration: none;
  }

  .post-title:hover {
    text-decoration: underline;
  }

  .post-excerpt {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 560px;
  }

  .read-more {
    font-size: 12px;
    color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border-hover);
    padding-bottom: 1px;
    align-self: flex-start;
  }

  .load-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
  }

  .load-btn {
    font-size: 12px;
    color: var(--color-text-secondary);
    background: transparent;
    border: 0.5px solid var(--color-border-hover);
    border-radius: var(--radius-md);
    padding: 6px 18px;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .load-btn:hover {
    background: var(--color-bg-secondary);
  }

  .load-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .count {
    font-size: 11px;
    color: var(--color-text-tertiary);
  }
</style>
